{
  "id": "bangumi-ui",
  "name": "Bangumi 番组计划",
  "version": "1.1.2",
  "manifestURI": "https://raw.githubusercontent.com/Elisoar111/seanime-extensions/main/Bangumi/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "Display Bangumi metadata in the Seanime sidebar: ratings, rank, score distribution, tags, production info, characters, episodes, related entries, and personal collection status. Supports manual binding.",
  "author": "Elisoar",
  "icon": "https://raw.githubusercontent.com/Elisoar111/seanime-extensions/main/Bangumi/icon.png",
  "website": "https://bgm.tv",
  "lang": "zh",
  "payloadURI": "https://raw.githubusercontent.com/Elisoar111/seanime-extensions/main/Bangumi/bangumi.plugin.js",
  "readme":"https://raw.githubusercontent.com/Elisoar111/seanime-extensions/main/Bangumi/README.md",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": [
        "storage"
      ],
      "allow": {
        "networkAccess": {
          "allowedDomains": [
            "api.bgm.tv",
            "bgm.tv",
            "*.bgm.tv",
            "api.bangumi.lol",
            "bangumi.lol",
            "*.bangumi.lol"
          ],
          "reasoning": "需要访问 Bangumi API 获取番剧评分与元数据；如配置镜像端点，请将对应域名加入此列表"
        }
      }
    }
  },
  "userConfig": {
    "version": 1,
    "requiresConfig": false,
    "fields": [
      {
        "type": "text",
        "name": "accessToken",
        "label": "Bangumi Access Token（可选,https://next.bgm.tv/demo/access-token；填写管理我的收藏状态）",
        "default": ""
      },
      {
        "type": "text",
        "name": "apiEndpoints",
        "label": "API 端点（英文逗号分隔多个；若无法访问可改用镜像 https://api.bangumi.lol）",
        "description": "默认官方 API，国内用户可改为 https://api.bangumi.lol",
        "default": "https://api.bgm.tv"
      },
      {
        "type": "switch",
        "name": "autoMatch",
        "label": "自动匹配 Bangumi 条目",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "loadCharacters",
        "label": "加载角色列表",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "loadEpisodes",
        "label": "加载章节列表",
        "default": "true"
      },
      {
        "type": "switch",
        "name": "loadRelations",
        "label": "加载关联条目",
        "default": "true"
      }
    ]
  }
}
